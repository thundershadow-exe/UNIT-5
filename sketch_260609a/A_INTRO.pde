void intro() {
  background(20, 20, 40);

  fill(255, 220, 50);
  textSize(64);
  text("BREAKOUT", width/2, height/2 - 60);

  fill(200, 200, 255);
  textSize(24);
  text("Click anywhere to start", width/2, height/2 + 20);

  fill(120, 120, 180);
  textSize(16);
  text("Use mouse to control paddle", width/2, height/2 + 60);
}
